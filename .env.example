# Amazon Business API / Login with Amazon
AMAZON_BUSINESS_CLIENT_ID=amzn1.application-oa2-client.example
AMAZON_BUSINESS_CLIENT_SECRET=replace_me
AMAZON_BUSINESS_REFRESH_TOKEN=Atzr|replace_me

# JP generally uses the FE regional endpoint. Override this if Amazon gives you a sandbox/prod endpoint.
AMAZON_BUSINESS_REGION=JP
AMAZON_BUSINESS_BASE_URL=https://fe.business-api.amazon.com
AMAZON_BUSINESS_BUYER_EMAIL=buyer@example.co.jp
AMAZON_BUSINESS_USER_AGENT=AmazonBusinessPurchaseAutomationAssistant/0.2.0 (Language=Python/3.11)

# Optional organization references generated/configured in Amazon Business.
AMAZON_BUSINESS_BUYING_GROUP_REFERENCE=replace_with_buying_group_reference
AMAZON_BUSINESS_PAYMENT_METHOD_REFERENCE=replace_with_payment_method_reference
AMAZON_BUSINESS_BUYER_REFERENCE=replace_with_buyer_reference
